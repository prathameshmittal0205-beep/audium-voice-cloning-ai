# Audium Required Environment Variables

# Backend Environment
PORT=8080
NODE_ENV=development

# Vercel Postgres URI (Required)
POSTGRES_URL=postgres://default:xxx@ep-xxx.pooler.supabase.com:5432/postgres

# Vercel Blob Token (Required)
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxx

# JWT Secret for Auth (Required)
AUDIUM_JWT_SECRET=your_secure_random_string

# Worker Registration Secret (Required)
WORKER_SECRET=your_secure_random_string

# Frontend Environment
VITE_AUDIUM_API_BASE_URL=/api
