# Audium Required Environment Variables

# Backend Environment
PORT=8080
NODE_ENV=development

# MongoDB Atlas URI (Required)
AUDIUM_MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/audium

# JWT Secret for Auth (Required)
AUDIUM_JWT_SECRET=your_secure_random_string

# Worker Registration Secret (Required)
WORKER_SECRET=your_secure_random_string

# Frontend Environment
VITE_AUDIUM_API_BASE_URL=https://your-render-app.onrender.com/api
