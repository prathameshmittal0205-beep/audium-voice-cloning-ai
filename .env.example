# Audium — Environment Configuration

# ── Audium GCP ───────────────────────────────────────────────
# Local dev only. Cloud Run uses Secret Manager to inject default service credentials automatically.
GOOGLE_APPLICATION_CREDENTIALS=./audium-service-account.json

# Distinct buckets for strict separation of concerns
AUDIUM_BUCKET_DATA=audium-voice-data
AUDIUM_BUCKET_MODELS=audium-models
AUDIUM_BUCKET_GENERATED=audium-generated

# The target Google Cloud Project ID hosting Vertex AI and Cloud Run infrastructure.
AUDIUM_VERTEX_PROJECT_ID=

# The Google Cloud region where Vertex AI endpoints and storage will reside.
AUDIUM_VERTEX_LOCATION=us-central1

# The unique identifier for the Vertex AI endpoint where the active model is deployed.
AUDIUM_VERTEX_ENDPOINT_ID=

# URI for the container image in Artifact Registry used by the CustomContainerTrainingJob.
AUDIUM_ARTIFACT_REGISTRY_IMAGE=

# ── Audium MongoDB ────────────────────────────────────────────
# MongoDB connection string.
# mongodb://localhost:27017/audium  (local)
# mongodb+srv://...@.../audium      (Atlas prod)
AUDIUM_MONGODB_URI=

# ── Audium Express ────────────────────────────────────────────
# Port where the Node.js/Express server listens. Cloud Run usually populates this automatically.
PORT=8080

# CORS protection: limits access to the Audium Express API strictly to the React UI's origin domain.
AUDIUM_ALLOWED_ORIGIN=http://localhost:5173

# Cryptographic secret used to sign JSON Web Tokens for user authentication.
AUDIUM_JWT_SECRET=super_secret_jwt_key_example

# The lifespan of the JWT token before requiring re-authentication.
AUDIUM_JWT_EXPIRY=7d

# ── Audium Frontend ───────────────────────────────────────────
# The publicly accessible URL of the deployed Express backend (Cloud Run or localhost).
REACT_APP_AUDIUM_API_BASE_URL=http://localhost:8080
