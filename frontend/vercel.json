{
  "build": {
    "env": {
      "VITE_XTTS_API_URL": "https://postlicentiate-flecklessly-mason.ngrok-free.dev"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://<render-backend-url>/api/$1"
    },
    {
      "source": "/((?!api).*)",
      "destination": "/index.html"
    }
  ]
}
